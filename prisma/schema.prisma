datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum Category {
  BIRTHDAY
  ANNIVERSARY
  WEDDING
  GRADUATION
  GRAND_OPENING
}

enum ImageType {
  COVER
  GALLERY
}

enum RsvpStatus {
  ATTENDING
  DECLINED
  UNSURE
}

model User {
  id          String       @id @default(cuid())
  name        String?
  email       String       @unique
  password    String // Hashed password
  role        Role         @default(USER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  invitations Invitation[]

  @@map("users")
}

model Template {
  id            String       @id @default(cuid())
  name          String
  defaultConfig Json
  isTemplate    Boolean      @default(true)
  category      String       @default("WEDDING") // Thêm dòng này
  createdAt     DateTime     @default(now())
  invitations   Invitation[]

  @@map("templates")
}

model Invitation {
  id               String   @id @default(cuid())
  slug             String   @unique // e.g., "wedding-linh-hung"
  title            String // Display name in admin panel
  category         Category
  eventData        Json // Stores names, times, location, maps url dynamically
  themeConfig      Json // Active dynamic configuration layout/sections
  openingAnimation String // e.g., "envelope", "gift_box"
  isPublished      Boolean  @default(false)

  // Relations
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Restrict)
  musicId    String?
  music      Music?   @relation(fields: [musicId], references: [id], onDelete: SetNull)

  images    InvitationImage[]
  rsvps     Rsvp[]
  views     View[]
  analytics Analytics[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guestbookEntries GuestbookEntry[]

  @@index([userId])
  @@index([templateId])
  @@map("invitations")
}

model InvitationImage {
  id           String     @id @default(cuid())
  url          String
  publicId     String?    // Để xóa ảnh trên Cloudinary nếu cần
  type         String     // 'hero' hoặc 'gallery'
  order        Int        @default(0) // <--- Trường sắp xếp
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id])
  createdAt    DateTime   @default(now())

  @@index([invitationId])
  @@map("invitation_images")
}

model Music {
  id          String       @id @default(cuid())
  name        String // Title of the song
  url         String // Cloudinary secure audio link
  publicId    String? // Nullable for predefined seed music
  category    Category
  isCustom    Boolean      @default(false)
  invitations Invitation[]

  createdAt DateTime @default(now())

  @@map("music")
}

model Rsvp {
  id          String     @id @default(cuid())
  name        String
  phone       String?
  guestsCount Int        @default(1)
  status      RsvpStatus @default(ATTENDING)
  message     String?    @db.Text

  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invitationId])
  @@map("rsvp")
}

model View {
  id        String  @id @default(cuid())
  ip        String?
  userAgent String?

  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invitationId])
  @@map("views")
}

model Analytics {
  id         String   @id @default(cuid())
  date       DateTime @default(now()) @db.Date
  viewsCount Int      @default(0)
  rsvpCount  Int      @default(0)

  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@unique([invitationId, date])
  @@map("analytics")
}

model GuestbookEntry {
  id           String   @id @default(cuid())
  invitationId String
  name         String
  message      String
  createdAt    DateTime @default(now())

  // Liên kết với thiệp
  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
}
